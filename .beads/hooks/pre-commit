#!/usr/bin/env sh
# --- BEGIN BEADS INTEGRATION v0.59.0 ---
# This section is managed by beads. Do not remove these markers.
if command -v bd >/dev/null 2>&1; then
  export BD_GIT_HOOK=1
  bd hooks run pre-commit "$@"
  _bd_exit=$?; if [ $_bd_exit -ne 0 ]; then exit $_bd_exit; fi
fi
# --- END BEADS INTEGRATION v0.59.0 ---

# --- BEGIN custom: stage freshly-exported JSONL into the commit ---
# Lives OUTSIDE bd's managed markers so bd upgrades won't clobber it.
# Pairs with `bd config set export.git-add false` — auto-staging is off
# mid-work (no checkout pain, no lock races), but commits still include
# the snapshot because bd's pre-commit hook exports above and this
# block stages the result. -f bypasses .git/info/exclude.
git add -f .beads/issues.jsonl 2>/dev/null || true
# --- END custom ---
